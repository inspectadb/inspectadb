CREATE TABLE IF NOT EXISTS `<CHANGE_TABLE_SCHEMA>`.`<CHANGE_TABLE>` (
    `<CHANGE_ID>`     BIGINT NOT NULL AUTO_INCREMENT,
    `<CHANGE_ACTION>` VARCHAR(6) NOT NULL,
    `<CHANGED_BY>`    VARCHAR(200) DEFAULT NULL,
    `<CHANGED_AT>`    TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    PRIMARY KEY (`<CHANGE_ID>`)
) AS SELECT * FROM `<TRIGGER_TABLE_SCHEMA>`.`<TRIGGER_TABLE>` WHERE FALSE;