CREATE TABLE IF NOT EXISTS `<CHANGE_TABLE_SCHEMA>`.`<CHANGE_TABLE>` (
    `<AUDIT_ID>`     BIGINT NOT NULL AUTO_INCREMENT,
    `<AUDIT_ACTION>` VARCHAR(6) NOT NULL,
    `<AUDIT_USER>`   VARCHAR(200) DEFAULT NULL,
    `<AUDITED_AT>`   TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    PRIMARY KEY (`<AUDIT_ID>`)
) AS SELECT * FROM `<TRIGGER_TABLE_SCHEMA>`.`<TRIGGER_TABLE>` WHERE FALSE;